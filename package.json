{
  "name": "dawn",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build",
    "check": "turbo run check",
    "ci:validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm build && pnpm pack:check && node scripts/publish-smoke.mjs",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "pack:check": "node scripts/pack-check.mjs",
    "test": "node scripts/test.mjs",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@changesets/cli": "2.30.0",
    "publint": "0.3.15",
    "turbo": "2.9.6",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
