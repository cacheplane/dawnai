{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "paths": {
      "@dawnai.org/core": ["../core/src/index.ts"],
      "@dawnai.org/langgraph": ["../langgraph/src/index.ts"],
      "@dawnai.org/langgraph/*": ["../langgraph/src/*.ts"]
    },
    "rootDir": "src"
  },
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../core"
    },
    {
      "path": "../langgraph"
    }
  ]
}
