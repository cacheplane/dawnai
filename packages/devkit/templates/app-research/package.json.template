{
  "name": "{{appName}}",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dawn dev --port 3000",
    "check": "dawn check",
    "eval": "dawn eval",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:sandbox:docker": "DAWN_DEMO_DOCKER_SANDBOX=1 vitest run test/sandbox-docker.test.ts",
    "memory:list": "dawn memory list",
    "memory:approve": "dawn memory approve",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dawn-ai/core": "{{dawnCoreSpecifier}}",
    "@dawn-ai/cli": "{{dawnCliSpecifier}}",
    "@dawn-ai/langchain": "{{dawnLangchainSpecifier}}",
    "@dawn-ai/sandbox": "{{dawnSandboxSpecifier}}",
    "@dawn-ai/sdk": "{{dawnSdkSpecifier}}",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@dawn-ai/config-typescript": "{{dawnConfigTypescriptSpecifier}}",
    "@dawn-ai/evals": "{{dawnEvalsSpecifier}}",
    "@dawn-ai/testing": "{{dawnTestingSpecifier}}",
    "@types/node": "25.6.0",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
